# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_NAME=your_bot
TELEGRAM_CHAT_ID=123456789
ADMIN_TELEGRAM_IDS=123456789

# Wallet and encryption
PRIVATE_KEY=your_base58_private_key
ENCRYPTION_KEY=generate_with_cryptography_fernet

# PostgreSQL and Redis
DATABASE_URL=postgresql://savage:savage@localhost:5432/savage_trading
POSTGRES_PASSWORD=savage
REDIS_URL=redis://localhost:6379/0

# Dashboard auth and URLs
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRE_HOURS=72
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=3000
BACKEND_PORT=8000
FRONTEND_API_URL=http://localhost:8000
FRONTEND_WS_URL=ws://localhost:8000

# RPC endpoints
RPC_URL_SOL=https://api.mainnet-beta.solana.com
RPC_URL_ETH=https://mainnet.infura.io/v3/YOUR_KEY
RPC_URL_BSC=https://bsc-dataseed1.binance.org

# Market data APIs
DEXTOOLS_API_KEY=
DEXTOOLS_PLAN=trial
BIRDEYE_API_KEY=
HELIUS_API_KEY=

# Chain selection
CHAIN=SOL

# Trading
BUY_PERCENT=50
TAKE_PROFIT=20
STOP_LOSS=-30
TRAILING_ENABLED=true
TRAILING_DROP=10
SLIPPAGE=15
SELL_TIERS=50:50,100:25
TP1_PERCENT=50
TP1_SELL_PERCENT=50
TP2_PERCENT=100
TRAILING_SL_PERCENT=15
DAILY_LOSS_LIMIT_PCT=20

# Filters
MIN_LIQUIDITY=5000
MAX_MCAP=500000
MIN_MCAP=10000
MIN_SCORE=40

# Risk management
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS=2.0
MAX_BUY_AMOUNT=1.0
COMPOUND_ENABLED=false
COMPOUND_PERCENT=50

# Intervals
SCAN_INTERVAL=60
MONITOR_INTERVAL=30

# Whale tracking and copy trading
WHALE_TRACKING_ENABLED=true
WHALE_CHECK_INTERVAL=45
WHALE_MIN_SOL=1.0
WHALE_COPY_ENABLED=false
WHALE_COPY_AMOUNT=0.1
WHALE_COPY_MAX_PER_TOKEN=1

# Anti-rug
ANTIRUG_ENABLED=true
ANTIRUG_MIN_LIQ=1000
ANTIRUG_LIQ_DROP_PCT=70

# Pump.fun
PUMPFUN_ENABLED=true
PUMPFUN_SCAN_INTERVAL=30
PUMPFUN_MIN_BONDING_PCT=75
PUMPFUN_MAX_AGE_HOURS=2.0
PUMPFUN_MIN_DEV_SCORE=40
PUMPFUN_DIP_BUY_PCT=20

# Operator fee
OPERATOR_FEE_ENABLED=true
OPERATOR_FEE_PCT=5

# Legacy bot API
API_ENABLED=false
API_PORT=8080
API_KEY=your-secret-api-key-here
ALERT_BROADCAST=false

# Sniper
SNIPER_ENABLED=false
SNIPER_CHECK_INTERVAL=10
SNIPER_MIN_LIQUIDITY=1000
